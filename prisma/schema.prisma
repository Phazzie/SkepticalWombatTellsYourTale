generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id          String     @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  documents   Document[]
  sessions    Session[]
  tangents    Tangent[]
  patterns    Pattern[]
  gaps        Gap[]
  questions   Question[]
  concepts    Concept[]
  contradictions Contradiction[]
}

model Document {
  id          String    @id @default(uuid())
  projectId   String
  name        String
  type        String    @default("general")
  content     String    @default("")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Session {
  id            String      @id @default(uuid())
  projectId     String
  questionId    String?
  audioUrl      String?
  transcript    String      @default("")
  aiAnnotations String      @default("[]")
  tangents      Tangent[]
  promptedBy    Question?   @relation(fields: [questionId], references: [id], onDelete: SetNull)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  project       Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Tangent {
  id          String    @id @default(uuid())
  projectId   String
  sessionId   String
  thread      String
  context     String    @default("")
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  session     Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Pattern {
  id          String    @id @default(uuid())
  projectId   String
  description String
  sessionRefs String    @default("[]")
  acknowledged Boolean  @default(false)
  createdAt   DateTime  @default(now())
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Gap {
  id          String    @id @default(uuid())
  projectId   String
  description String
  documentRef String?
  resolved    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Question {
  id          String    @id @default(uuid())
  projectId   String
  text        String
  sessionRef  String?
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  responses   Session[]
}

model Concept {
  id            String    @id @default(uuid())
  projectId      String
  name           String
  definition     String
  sourceSession  String?
  linkedDocument String?
  status         String    @default("developing")
  approved       Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Contradiction {
  id          String    @id @default(uuid())
  projectId   String
  description String
  existing    String
  new         String
  status      String    @default("open")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
