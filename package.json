{
  "name": "skeptical-wombat-tells-your-tale",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test:unit": "npx tsx --test src/lib/server/**/*.test.ts src/app/api/__tests__/*.test.ts",
    "verify": "npm run lint && npm run build",
    "test": "npm run verify",
    "db:bootstrap": "DATABASE_URL='file:./dev.db' npx prisma db push && npx prisma generate",
    "preflight": "npm ci && npm run db:bootstrap",
    "verify:postchange": "npm run verify",
    "security:audit": "npm audit --audit-level=high",
    "agent:run": "npm run preflight && npm run verify:postchange"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.22.0",
    "next": "15.5.14",
    "next-auth": "^4.24.13",
    "openai": "^6.33.0",
    "prisma": "^5.22.0",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "dotenv": "^17.4.0",
    "eslint": "^8",
    "eslint-config-next": "15.5.14",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
