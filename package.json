{
  "name": "skeptical-wombat-tells-your-tale",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test:unit": "node scripts/run-unit-tests.mjs",
    "smoke:test": "node scripts/smoke-test.mjs",
    "verify": "npm run lint && npm run build",
    "test": "npm run verify && npm run test:unit",
    "db:bootstrap": "npx prisma db push && npx prisma generate",
    "preflight": "npm ci && npm run db:bootstrap",
    "verify:postchange": "npm run verify",
    "security:audit": "npm audit --audit-level=high",
    "agent:run": "npm run preflight && npm run verify:postchange",
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.22.0",
    "next": "15.5.15",
    "next-auth": "^4.24.13",
    "openai": "^6.33.0",
    "prisma": "^5.22.0",
    "react": "^18",
    "react-dom": "^18",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.4.0",
    "eslint": "^8",
    "eslint-config-next": "15.5.15",
    "jsdom": "^29.1.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
