# Database
DATABASE_URL="file:./dev.db"

# OpenAI — required for transcription (Whisper) and analysis (GPT-4o)
OPENAI_API_KEY="your-openai-api-key-here"

# NextAuth — both are required in production
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
# Or with Node: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="replace-with-a-strong-random-secret-min-32-chars"
# Set NEXTAUTH_URL to your production domain (include protocol, no trailing slash)
NEXTAUTH_URL="http://localhost:3000"
