# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/skeptical_wombat?schema=public"

# OpenAI — required for transcription (Whisper) and analysis (GPT-4o)
OPENAI_API_KEY="your-openai-api-key-here"

# NextAuth — required in production
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-strong-random-secret-min-32-chars"
# Canonical app URL (include protocol, no trailing slash)
NEXTAUTH_URL="http://localhost:3000"
